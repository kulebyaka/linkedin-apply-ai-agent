# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# LinkedIn Credentials
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password
LINKEDIN_API_KEY=  # Optional, if you have API access

# LLM Configuration
PRIMARY_LLM_PROVIDER=openai  # openai, deepseek, grok, anthropic
FALLBACK_LLM_PROVIDER=deepseek

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Grok (X.AI)
GROK_API_KEY=
GROK_MODEL=grok-2-1212

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4.5

# Paths
DATA_DIR=./data
CV_DIR=./data/cv
JOBS_DIR=./data/jobs
GENERATED_CVS_DIR=./data/generated_cvs
MASTER_CV_PATH=./data/cv/master_cv.json
PROMPTS_DIR=./prompts/cv_composer

# Repository
REPO_TYPE=memory  # "memory" or "sqlite"
DB_PATH=./data/jobs.db

# CV Template
CV_TEMPLATE_DIR=src/templates/cv
CV_TEMPLATE_NAME=compact  # modern, compact, classic, minimal, profile-card

# LinkedIn Search Settings
LINKEDIN_SEARCH_KEYWORDS=software engineer
LINKEDIN_SEARCH_LOCATION=United States
LINKEDIN_SEARCH_REMOTE_FILTER=  # "remote", "on-site", "hybrid"
LINKEDIN_SEARCH_DATE_POSTED=  # "24h", "week", "month"
LINKEDIN_SEARCH_EXPERIENCE_LEVEL=  # JSON list: ["entry", "mid-senior"]
LINKEDIN_SEARCH_JOB_TYPE=  # JSON list: ["full-time", "contract"]
LINKEDIN_SEARCH_EASY_APPLY_ONLY=false
LINKEDIN_SEARCH_MAX_JOBS=50
LINKEDIN_SESSION_COOKIE_PATH=./data/linkedin_cookies.json
LINKEDIN_MIN_DELAY=3.0
LINKEDIN_MAX_DELAY=8.0
LINKEDIN_PAGE_DELAY_MIN=2.0
LINKEDIN_PAGE_DELAY_MAX=5.0

# LinkedIn Search Scheduler
LINKEDIN_SEARCH_SCHEDULE_ENABLED=false
LINKEDIN_SEARCH_INTERVAL_HOURS=1

# Job Fixture Record & Replay (for HITL testing and demos)
SEED_JOBS_FROM_FILE=false  # Load jobs from fixture file instead of scraping LinkedIn
SCRAPED_JOBS_PATH=./data/jobs/scraped_jobs.json  # Fixture file path
SEED_JOBS_LIMIT=0  # Max jobs to replay from file (0 = no limit)

# Workflow Settings
JOB_FETCH_INTERVAL_HOURS=1
MAX_CONCURRENT_APPLICATIONS=3
BROWSER_HEADLESS=true

# CV Composer
CV_COMPOSER_TEMPERATURE_SUMMARY=0.5
CV_COMPOSER_TEMPERATURE_JOB_ANALYSIS=0.3
CV_COMPOSER_TEMPERATURE_SECTIONS=0.4
CV_COMPOSER_MAX_RETRIES=3
CV_COMPOSER_ENABLE_HALLUCINATION_CHECKS=true
CV_COMPOSER_MODEL_OVERRIDE=  # Override LLM model for CV composition

# CV Content Limits
CV_MAX_EXPERIENCES=4
CV_MAX_ACHIEVEMENTS_PER_EXPERIENCE=4
CV_MAX_SKILLS=15
CV_MAX_PROJECTS=2
CV_MAX_CERTIFICATIONS=4
CV_TARGET_PAGES=2

# Notifications
WEBHOOK_URL=  # Discord, Slack, or custom webhook URL
NOTIFICATION_EMAIL=

# API Server (for HITL UI)
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# UI Settings (Vite — prefix with VITE_ to expose to frontend)
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK=false
