# =============================================================================
# SECRETS — must be set in .env; never commit real values
# =============================================================================

# LinkedIn login (required for scraping features)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# LLM API keys — set at least one
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=

# Magic-link email service — https://resend.com
RESEND_API_KEY=

# JWT signing key — generate with: openssl rand -hex 32
JWT_SECRET=

# =============================================================================
# ENVIRONMENT-SPECIFIC — differ across dev / staging / production
# =============================================================================

# Application
DEBUG=false
LOG_LEVEL=INFO

# LLM provider selection
PRIMARY_LLM_PROVIDER=openai      # openai | deepseek | grok | anthropic
FALLBACK_LLM_PROVIDER=deepseek

# LLM model overrides (defaults are in settings.py; only set to change them)
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-chat
GROK_MODEL=grok-2-1212
ANTHROPIC_MODEL=claude-sonnet-4.5

# Repository backend
REPO_TYPE=memory                 # memory (dev) | sqlite (production)

# LinkedIn search — global fallback when no user prefs are stored in DB
LINKEDIN_SEARCH_KEYWORDS=
LINKEDIN_SEARCH_LOCATION=
LINKEDIN_SEARCH_REMOTE_FILTER=      # remote | on-site | hybrid
LINKEDIN_SEARCH_DATE_POSTED=        # 24h | week | month
LINKEDIN_SEARCH_EXPERIENCE_LEVEL=   # JSON list: ["entry","mid-senior"]
LINKEDIN_SEARCH_JOB_TYPE=           # JSON list: ["full-time","contract"]

# LinkedIn scheduler
LINKEDIN_SEARCH_SCHEDULE_ENABLED=false

# Development toggles
SEED_JOBS_FROM_FILE=false        # Load jobs from fixture file instead of scraping
BROWSER_HEADLESS=true            # Set to false for visual debugging

# Magic link
APP_URL=http://localhost:5173    # Base URL for magic link callback (change in production)
RESEND_FROM=LinkedIn Agent <noreply@resend.dev>  # Must be a verified Resend domain

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:8000","http://localhost:8000"]

# Frontend (Vite — VITE_ prefix required to expose to the browser)
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK=false

# =============================================================================
# OPTIONAL OVERRIDES — have sensible defaults; uncomment only if needed
# =============================================================================

# LINKEDIN_API_KEY=              # LinkedIn API access (rare)
# CV_COMPOSER_MODEL_OVERRIDE=    # Override LLM model for CV composition only
# CV_TEMPLATE_NAME=compact       # modern | compact | classic | minimal | profile-card
# WEBHOOK_URL=                   # Discord / Slack / custom webhook for notifications
# NOTIFICATION_EMAIL=            # Email address for notifications
